{
  "_comment": "Example AtlasClaw configuration. This file stays valid JSON by using _comment fields instead of // comments.",
  "providers_root": "../atlasclaw-providers/providers",

  "model": {
    "_comment": "Primary LLM configuration. Replace provider/model and env vars to match your deployment.",
    "primary": "deepseek/deepseek-chat",
    "fallbacks": [],
    "temperature": 0.2,
    "providers": {
      "deepseek": {
        "_comment": "OpenAI-compatible DeepSeek endpoint. Requires DS_API_KEY in the environment or .env.",
        "base_url": "https://api.deepseek.com",
        "api_key": "${DS_API_KEY}",
        "api_type": "openai"
      }
    }
  },

  "service_providers": {
    "_comment": "Enterprise system instances used by skills. Instance names like dev/prod are referenced at runtime.",
    "jira": {
      "dev": {
        "_comment": "Jira supports either password or token. Keep only the one you actually use.",
        "base_url": "https://jira-dev.example.com/",
        "username": "${JIRA_USERNAME}",
        "password": "${JIRA_PASSWORD}",
        "api_version": "2",
        "default_project": "TEST"
      }
    }
  },

  "webhook": {
    "_comment": "Inbound webhook dispatch for provider-qualified markdown skills already loaded from providers_root.",
    "enabled": true,
    "header_name": "X-AtlasClaw-SK",
    "systems": [
      {
        "_comment": "One external caller. sk_env points to the shared secret variable, typically defined in .env.",
        "system_id": "smartcmp-preapproval",
        "enabled": true,
        "sk_env": "ATLASCLAW_WEBHOOK_SK_SMARTCMP_PREAPPROVAL",
        "default_agent_id": "main",
        "allowed_skills": [
          "smartcmp:preapproval-agent"
        ]
      }
    ]
  },

  "auth": {
    "_comment": "Optional API authentication config for normal REST/UI access. Webhook secret auth is configured separately above.",
    "provider": "none",
    "cache_ttl_seconds": 300,

    "smartcmp": {
      "validate_url": "https://smartcmp.example.com/platform-api/auth/validate",
      "api_base_url": "https://smartcmp.example.com"
    },

    "oidc": {
      "_comment": "OIDC/OAuth2 configuration for Bearer token validation and SSO login flow",
      "issuer": "https://auth.example.com",
      "client_id": "${OIDC_CLIENT_ID}",
      "client_secret": "${OIDC_CLIENT_SECRET}",
      "jwks_uri": "",
      "scopes": ["openid", "profile", "email"],
      "_comment_sso": "SSO login flow endpoints (auto-discovered from issuer if empty)",
      "authorization_endpoint": "",
      "token_endpoint": "",
      "userinfo_endpoint": "",
      "redirect_uri": "https://atlasclaw.example.com/api/auth/callback",
      "pkce_enabled": true,
      "pkce_method": "S256"
    },

    "api_key": {
      "keys": {
        "sk-dev-key-001": {
          "user_id": "dev-user",
          "roles": ["admin"]
        }
      }
    },

    "none": {
      "default_user_id": "default"
    }
  }
}
